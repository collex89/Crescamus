# Copy this file to .env and fill in your Supabase project values.
# Find them in your Supabase dashboard: Project Settings -> API.
# Then restart the dev server (npm run dev).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# Public VAPID key for Web Push (generate a pair with `npx web-push generate-vapid-keys`,
# set this to the public half; the private half + subject are Supabase Edge Function secrets,
# never client-side -- see SUPABASE_SETUP.md).
VITE_VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY
